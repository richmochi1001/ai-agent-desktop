{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist/electron",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "noImplicitAny": false
  },
  "include": [
    "electron/**/*",
    "skills/basic/**/*",
    "shared/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "src"
  ]
}
